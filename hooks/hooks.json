{
  "description": "git commit·세션 종료 시 intent 기록을 제안한다(제안만, 자동 기록·검수 생략 없음).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/suggest-on-commit.sh", "timeout": 10 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/suggest-on-stop.sh", "timeout": 10 }
        ]
      }
    ]
  }
}
